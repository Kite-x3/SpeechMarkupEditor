<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SpeechMarkupEditor.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:res="clr-namespace:SpeechMarkupEditor.Assets"
        xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Avalonia.Svg.Skia"
        xmlns:conv="clr-namespace:SpeechMarkupEditor.Infrastructure.Converters"
        xmlns:controls="using:SpeechMarkupEditor.Controls"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="SpeechMarkupEditor.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/SpeechMarkEditor.png"
        Title="{x:Static res:Resources.AppTitle}">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Resources>
        <conv:TimeToStringConverter x:Key="TimeToStringConverter"/>
        <SolidColorBrush x:Key="LeftLetter" Color="#536699"/>
        <SolidColorBrush x:Key="RightLetter" Color="#CC6666"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.toolbar">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Width" Value="36"></Setter>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style Selector="Border.PanelStyle">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto, Auto, *" Margin="15, 10" RowSpacing="8">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Top">
            <DropDownButton Content="{x:Static res:Resources.File}"
                            Width="120">
                <DropDownButton.Flyout>
                    <MenuFlyout Placement="BottomEdgeAlignedLeft">
                        <MenuItem Header="{x:Static res:Resources.SelectWavFile}"
                                  Command="{Binding SelectWavFileCommand}">
                        </MenuItem>

                        <MenuItem Header="Экспорт"
                                  Command="{Binding ExportCommand}"
                                  IsEnabled="{Binding IsFileSelected}">
                        </MenuItem>
                    </MenuFlyout>
                </DropDownButton.Flyout>
            </DropDownButton>
            <Button Classes="toolbar" Command="{Binding TogglePlayPauseCommand}"
                    IsEnabled="{Binding IsFileSelected}">
                <StackPanel>
                    <svg:Svg Path="avares://SpeechMarkupEditor/Assets/play.svg"
                             Width="30" Height="30"
                             IsVisible="{Binding !IsPlaying}"/>
                    <svg:Svg Path="avares://SpeechMarkupEditor/Assets/pause.svg"
                             Width="30" Height="30"
                             IsVisible="{Binding IsPlaying}"/>
                </StackPanel>
            </Button>
            <Button Classes="toolbar" Command="{Binding StopCommand}"
                    IsEnabled="{Binding IsFileSelected}">
                <svg:Svg Path="avares://SpeechMarkupEditor/Assets/stop.svg" Width="20" Height="20"></svg:Svg>
            </Button>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding VolumePercentage, StringFormat={}{0:F0}%}" Width="40" VerticalAlignment="Center"
                           HorizontalAlignment="Right"></TextBlock>
                <Slider Width="100" Minimum="0" Maximum="1" Value="{Binding Volume, Mode=TwoWay}"
                        IsEnabled="{Binding IsFileSelected}"></Slider>
            </StackPanel>
            <Button Classes="toolbar" Command="{Binding ToggleLeftChannelCommand}" IsEnabled="{Binding IsStereoAudio}">
                <StackPanel>
                    <TextBlock Text="L" HorizontalAlignment="Center"/>
                    <svg:Svg Path="avares://SpeechMarkupEditor/Assets/sound-on.svg"
                             Width="20" Height="20"
                             IsVisible="{Binding IsLeftChannelActive}"/>
                    <svg:Svg Path="avares://SpeechMarkupEditor/Assets/sound-off.svg"
                             Width="20" Height="20"
                             IsVisible="{Binding !IsLeftChannelActive}"/>
                </StackPanel>
            </Button>
            <Button Classes="toolbar" Command="{Binding ToggleRightChannelCommand}" IsEnabled="{Binding IsStereoAudio}">
                <StackPanel>
                    <TextBlock Text="R" HorizontalAlignment="Center"/>
                    <svg:Svg Path="avares://SpeechMarkupEditor/Assets/sound-on.svg"
                             Width="20" Height="20"
                             IsVisible="{Binding IsRightChannelActive}"/>
                    <svg:Svg Path="avares://SpeechMarkupEditor/Assets/sound-off.svg"
                             Width="20" Height="20"
                             IsVisible="{Binding !IsRightChannelActive}"/>
                </StackPanel>
            </Button>
            <TextBlock Text="{Binding SelectedFileName}" VerticalAlignment="Center"/>
        </StackPanel>
        <Grid Grid.Row="1" Margin="0,20,8,0" IsVisible="{Binding IsFileSelected}"
              ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <controls:WaveformControl x:Name="WaveformControl" Grid.Column="0"
                                      Minimum="0" Maximum="{Binding TotalTimeSeconds}"
                                      Value="{Binding CurrentTimeSeconds, Mode=TwoWay}"
                                      WaveformBrush="{StaticResource LeftLetter}" PlayedWaveformBrush="{StaticResource RightLetter}"
                                      CursorBrush="{StaticResource RightLetter}" CursorWidth="2"
                                      Height="60">
                <controls:WaveformControl.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="{x:Static res:Resources.AddWord}"
                                  Command="{Binding AddWordMarkerCommand}"
                                  CommandParameter="{Binding #WaveformControl.RightClickPosition}"/>
                    </ContextMenu>
                </controls:WaveformControl.ContextMenu>
            </controls:WaveformControl>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" >
                <TextBlock Text="{Binding CurrentTimeSeconds, Converter={StaticResource TimeToStringConverter}}"
                           Width="70" TextAlignment="Right"></TextBlock>
                <TextBlock Text="/" Margin="2,0"></TextBlock>
                <TextBlock Text="{Binding TotalTimeSeconds, Converter={StaticResource TimeToStringConverter}}"
                           Width="70" TextAlignment="Left"></TextBlock>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="2" ColumnDefinitions="*, *" RowDefinitions="Auto, Auto, *, Auto" ColumnSpacing="32" RowSpacing="8">
            <Border Grid.Row="0" Grid.ColumnSpan="2" BorderBrush="Gray" BorderThickness="2"
                    Margin="0, 0, 0, 8" Padding="0, 8" HorizontalAlignment="Stretch" CornerRadius="4">
                <StackPanel Spacing="8">
                    <TextBlock Text="{x:Static res:Resources.AudioProcessing}" FontSize="16" HorizontalAlignment="Center"
                               IsVisible="{Binding IsProcessingAudio}"></TextBlock>
                    <ProgressBar Width="300" Height="8" IsIndeterminate="True"
                                 IsVisible="{Binding IsProcessingAudio}"
                                 VerticalAlignment="Center"/>
                    <Button Content="{x:Static res:Resources.Cancel}"
                            Command="{Binding CancelRecognitionCommand}"
                            IsVisible="{Binding IsProcessingAudio}"
                            HorizontalAlignment="Center"/>
                    <TextBlock HorizontalAlignment="Center" Text="{x:Static res:Resources.WordsInAudioFile}"
                               IsVisible="{Binding !IsProcessingAudio}" FontSize="16"></TextBlock>
                </StackPanel>
            </Border>
            <!-- Заголовки L / R -->
            <TextBlock Grid.Row="1" Text="L" Grid.Column="0" HorizontalAlignment="Center"
                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource LeftLetter}"/>
            <TextBlock Grid.Row="1" Text="R" Grid.Column="1" HorizontalAlignment="Center"
                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource RightLetter}"/>

            <!-- Левая панель -->
            <Border Grid.Row="2" Grid.Column="0" Classes="PanelStyle" BorderBrush="{StaticResource LeftLetter}"
                    BorderThickness="1.5">
                <Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding LeftSeries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10" Margin="0,0,0,10" BorderBrush="Gray" BorderThickness="0,0,0,2">
                                        <StackPanel>
                                            <!-- Заголовок серии -->
                                            <TextBlock Text="{Binding SeriesNumber, StringFormat='Серия {0}'}"
                                                      FontWeight="Bold"
                                                      Foreground="{StaticResource LeftLetter}"
                                                      Margin="0,0,0,5"/>

                                            <!-- Слова в сериях -->
                                            <ItemsControl ItemsSource="{Binding Words}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Margin="6,2" Spacing="8">
                                                            <TextBlock Text="{x:Static res:Resources.Word}"
                                                                      VerticalAlignment="Center"/>
                                                            <TextBox Text="{Binding Word}"
                                                                    FontWeight="Bold"/>
                                                            <TextBlock Text="{x:Static res:Resources.WordTiming}"
                                                                      VerticalAlignment="Center"/>
                                                            <NumericUpDown Value="{Binding StartTime}"
                                                                          Minimum="0"
                                                                          Increment="0.05"
                                                                          FormatString="0.00"/>
                                                            <TextBlock Text="-" VerticalAlignment="Center"/>
                                                            <NumericUpDown Value="{Binding EndTime}"
                                                                          Minimum="0"
                                                                          Increment="0.05"
                                                                          FormatString="0.00"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
            <!-- Правая панель -->
            <Border Grid.Row="2" Grid.Column="1" Classes="PanelStyle" BorderBrush="{StaticResource RightLetter}"
                    BorderThickness="1.5">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding RightSeries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10" Margin="0,0,0,10" BorderBrush="Gray" BorderThickness="0,0,0,2">
                                    <StackPanel>
                                        <!-- Заголовок серии -->
                                        <TextBlock Text="{Binding SeriesNumber, StringFormat='Серия {0}'}"
                                                  FontWeight="Bold"
                                                  Foreground="{StaticResource RightLetter}"
                                                  Margin="0,0,0,5"/>

                                        <!-- Слова в серии -->
                                        <ItemsControl ItemsSource="{Binding Words}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="6,2" Spacing="8">
                                                        <TextBlock Text="{x:Static res:Resources.Word}"
                                                                  VerticalAlignment="Center"/>
                                                        <TextBox Text="{Binding Word}"
                                                                FontWeight="Bold"/>
                                                        <TextBlock Text="{x:Static res:Resources.WordTiming}"
                                                                  VerticalAlignment="Center"/>
                                                        <NumericUpDown Value="{Binding StartTime}"
                                                                      Minimum="0"
                                                                      Increment="0.05"
                                                                      FormatString="0.00"/>
                                                        <TextBlock Text="-" VerticalAlignment="Center"/>
                                                        <NumericUpDown Value="{Binding EndTime}"
                                                                      Minimum="0"
                                                                      Increment="0.05"
                                                                      FormatString="0.00"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>

</Window>
