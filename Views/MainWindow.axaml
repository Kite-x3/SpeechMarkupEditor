<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SpeechMarkupEditor.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:res="clr-namespace:SpeechMarkupEditor.Assets"
        xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Avalonia.Svg.Skia"
        xmlns:conv="clr-namespace:SpeechMarkupEditor.Infrastructure.Converters"
        xmlns:controls="using:SpeechMarkupEditor.Controls"
        mc:Ignorable="d"
        x:Class="SpeechMarkupEditor.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/SpeechMarkEditor.png"
        Title="{x:Static res:Resources.AppTitle}">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Resources>
        <conv:TimeToStringConverter x:Key="TimeToStringConverter"/>
        <SolidColorBrush x:Key="LeftLetter" Color="#536699"/>
        <SolidColorBrush x:Key="RightLetter" Color="#CC6666"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.toolbar">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Button.channel-toggle">
            <Setter Property="Padding" Value="4,2"/>
        </Style>
        <Style Selector="DropDownButton.toolbar">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="DropDownButton.settings">
            <Setter Property="Width" Value="56"/>
        </Style>
        <Style Selector="Button.toolbar-text">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="DropDownButton.toolbar-text">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="svg|Svg.channel-icon">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style Selector="Button.action">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.delete-word">
            <Setter Property="Background" Value="#C75A5A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#B24E4E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Button.delete-word:pointerover">
            <Setter Property="Background" Value="#B24E4E"/>
        </Style>
        <Style Selector="Border.PanelStyle">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
        <Style Selector="Border.toolbar-panel">
            <Setter Property="BorderBrush" Value="#D8D8D8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Background" Value="#FAFAFA"/>
        </Style>
        <Style Selector="Border.info-panel">
            <Setter Property="BorderBrush" Value="#D8D8D8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,*" Margin="15,10" RowSpacing="10">
        <Border Grid.Row="0" Classes="toolbar-panel">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <DropDownButton Classes="toolbar settings">
                        <DropDownButton.Content>
                            <svg:Svg Path="avares://SpeechMarkupEditor/Assets/settings.svg"
                                     Width="20" Height="20"/>
                        </DropDownButton.Content>
                        <DropDownButton.Flyout>
                            <Flyout Placement="BottomEdgeAlignedLeft">
                                <StackPanel Spacing="8" VerticalAlignment="Stretch">
                                    <Button Content="{x:Static res:Resources.SelectRecognitionModel}"
                                            Click="ModelSettingsMenuItem_OnClick"
                                            HorizontalAlignment="Stretch"/>
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <TextBlock Text="Серии" VerticalAlignment="Center"/>
                                        <ToggleSwitch VerticalAlignment="Center"
                                                      IsChecked="{Binding ShowSeries, Mode=TwoWay}"
                                                      OnContent="Вкл"
                                                      OffContent="Выкл"/>
                                    </StackPanel>
                                </StackPanel>
                            </Flyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>

                    <DropDownButton Classes="toolbar-text" Width="104">
                        <DropDownButton.Content>
                            <TextBlock Text="{x:Static res:Resources.File}" FlowDirection="LeftToRight"/>
                        </DropDownButton.Content>
                        <DropDownButton.Flyout>
                            <MenuFlyout Placement="BottomEdgeAlignedLeft">
                                <MenuItem Header="{x:Static res:Resources.SelectWavFile}"
                                          Command="{Binding SelectWavFileCommand}"/>
                                <MenuItem Header="{x:Static res:Resources.OpenHistory}"
                                          Click="OpenHistoryMenuItem_OnClick"/>
                                <MenuItem Header="{x:Static res:Resources.ImportMarkup}"
                                          Command="{Binding ImportMarkupCommand}"/>
                                <MenuItem Header="{x:Static res:Resources.ExportMarkup}"
                                          Command="{Binding ExportCommand}"
                                          IsEnabled="{Binding IsFileSelected}"/>
                            </MenuFlyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>

                    <Button Classes="toolbar"
                            Command="{Binding TogglePlayPauseCommand}"
                            IsEnabled="{Binding HasAudioLoaded}">
                        <StackPanel>
                            <svg:Svg Path="avares://SpeechMarkupEditor/Assets/play.svg"
                                     Width="30" Height="30"
                                     IsVisible="{Binding !IsPlaying}"/>
                            <svg:Svg Path="avares://SpeechMarkupEditor/Assets/pause.svg"
                                     Width="30" Height="30"
                                     IsVisible="{Binding IsPlaying}"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="toolbar"
                            Command="{Binding StopCommand}"
                            IsEnabled="{Binding HasAudioLoaded}">
                        <svg:Svg Path="avares://SpeechMarkupEditor/Assets/stop.svg"
                                 Width="20"
                                 Height="20"/>
                    </Button>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="6">
                        <TextBlock Text="{Binding VolumePercentage, StringFormat={}{0:F0}%}"
                                   Width="40"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"/>
                        <Slider Width="96"
                                Minimum="0"
                                Maximum="1"
                                Value="{Binding Volume, Mode=TwoWay}"
                                IsEnabled="{Binding HasAudioLoaded}"/>
                    </StackPanel>

                    <Button Classes="toolbar channel-toggle"
                            Command="{Binding ToggleLeftChannelCommand}"
                            IsEnabled="{Binding IsStereoAudio}">
                        <Grid RowDefinitions="Auto,*" Height="36">
                            <TextBlock Grid.Row="0"
                                       Text="{x:Static res:Resources.LeftChannelShort}"
                                       FontSize="11"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Top"/>
                            <svg:Svg Path="avares://SpeechMarkupEditor/Assets/sound-on.svg"
                                     Grid.Row="1"
                                     Classes="channel-icon"
                                     IsVisible="{Binding IsLeftChannelActive}"/>
                            <svg:Svg Path="avares://SpeechMarkupEditor/Assets/sound-off.svg"
                                     Grid.Row="1"
                                     Classes="channel-icon"
                                     IsVisible="{Binding !IsLeftChannelActive}"/>
                        </Grid>
                    </Button>

                    <Button Classes="toolbar channel-toggle"
                            Command="{Binding ToggleRightChannelCommand}"
                            IsEnabled="{Binding IsStereoAudio}">
                        <Grid RowDefinitions="Auto,*" Height="36">
                            <TextBlock Grid.Row="0"
                                       Text="{x:Static res:Resources.RightChannelShort}"
                                       FontSize="11"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Top"/>
                            <svg:Svg Path="avares://SpeechMarkupEditor/Assets/sound-on.svg"
                                     Grid.Row="1"
                                     Classes="channel-icon"
                                     IsVisible="{Binding IsRightChannelActive}"/>
                            <svg:Svg Path="avares://SpeechMarkupEditor/Assets/sound-off.svg"
                                     Grid.Row="1"
                                     Classes="channel-icon"
                                     IsVisible="{Binding !IsRightChannelActive}"/>
                        </Grid>
                    </Button>
                </StackPanel>

                <Border Grid.Column="1"
                        Classes="info-panel"
                        VerticalAlignment="Stretch">
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="Текущий аудиофайл"
                                   FontSize="12"
                                   Foreground="#666666"/>
                        <TextBlock Text="{Binding SelectedFileName}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   MaxLines="2"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Classes="info-panel"
                        Width="320"
                        VerticalAlignment="Stretch">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="8" VerticalAlignment="Center">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Распознавание завершено"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           IsVisible="{Binding !IsProcessingAudio}"/>
                                <TextBlock Text="{x:Static res:Resources.AudioProcessing}"
                                           FontSize="13"
                                           Foreground="#666666"
                                           IsVisible="{Binding IsProcessingAudio}"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Classes="action"
                                    Command="{Binding RestartRecognitionCommand}"
                                    IsVisible="{Binding !IsProcessingAudio}"
                                    IsEnabled="{Binding HasAudioLoaded}"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <svg:Svg Path="avares://SpeechMarkupEditor/Assets/circle-reeat.svg"
                                                 Width="14"
                                                 Height="14"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>

                            <Button Grid.Column="1"
                                    Classes="action"
                                    Content="{x:Static res:Resources.Cancel}"
                                    Command="{Binding CancelRecognitionCommand}"
                                    IsVisible="{Binding IsProcessingAudio}"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"/>
                        </Grid>

                        <ProgressBar Grid.Row="1"
                                     Height="8"
                                     IsIndeterminate="True"
                                     IsVisible="{Binding IsProcessingAudio}"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="0,4,8,0"
              IsVisible="{Binding HasAudioLoaded}"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="8">
            <controls:WaveformControl x:Name="WaveformControl"
                                      Grid.Column="0"
                                      Minimum="0"
                                      Maximum="{Binding TotalTimeSeconds}"
                                      Value="{Binding CurrentTimeSeconds, Mode=TwoWay}"
                                      WaveformBrush="{StaticResource LeftLetter}"
                                      PlayedWaveformBrush="{StaticResource RightLetter}"
                                      CursorBrush="{StaticResource RightLetter}"
                                      CursorWidth="2"
                                      Height="60">
                <controls:WaveformControl.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="{x:Static res:Resources.AddWord}"
                                  Command="{Binding AddWordMarkerCommand}"
                                  CommandParameter="{Binding #WaveformControl.RightClickPosition}"/>
                    </ContextMenu>
                </controls:WaveformControl.ContextMenu>
            </controls:WaveformControl>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding CurrentTimeSeconds, Converter={StaticResource TimeToStringConverter}}"
                           Width="70"
                           TextAlignment="Right"/>
                <TextBlock Text="/" Margin="2,0"/>
                <TextBlock Text="{Binding TotalTimeSeconds, Converter={StaticResource TimeToStringConverter}}"
                           Width="70"
                           TextAlignment="Left"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="*, *" RowDefinitions="Auto,*" ColumnSpacing="32" RowSpacing="8">
            <TextBlock Grid.Row="0"
                       Text="{x:Static res:Resources.LeftChannelShort}"
                       Grid.Column="0"
                       HorizontalAlignment="Center"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="{StaticResource LeftLetter}"
                       IsVisible="{Binding !IsNonDichoticRecognition}"/>
            <TextBlock Grid.Row="0"
                       Text="{x:Static res:Resources.RightChannelShort}"
                       Grid.Column="1"
                       HorizontalAlignment="Center"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="{StaticResource RightLetter}"
                       IsVisible="{Binding !IsNonDichoticRecognition}"/>
            <TextBlock Grid.Row="0"
                       Grid.ColumnSpan="2"
                       Text="{x:Static res:Resources.Recognized}"
                       HorizontalAlignment="Center"
                       FontSize="16"
                       FontWeight="Bold"
                       IsVisible="{Binding IsNonDichoticRecognition}"/>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="{Binding LeftSeriesColumnSpan}"
                    Classes="PanelStyle"
                    BorderBrush="{StaticResource LeftLetter}"
                    BorderThickness="1.5">
                <Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,10,0" IsVisible="{Binding ShowSeries}">
                        <ItemsControl ItemsSource="{Binding LeftSeries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10" Margin="0,0,0,10" BorderBrush="Gray" BorderThickness="0,0,0,2">
                                        <StackPanel>
                                            <TextBlock Text="{Binding SeriesNumber, StringFormat={x:Static res:Resources.SeriesTitleFormat}}"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource LeftLetter}"
                                                       Margin="0,0,0,5"/>
                                            <ItemsControl ItemsSource="{Binding Words}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="6,4"
                                                              ColumnDefinitions="*,Auto,Auto"
                                                              ColumnSpacing="12">
                                                            <Grid Grid.Column="0" ColumnDefinitions="Auto,*" ColumnSpacing="6">
                                                                <TextBlock Grid.Column="0"
                                                                           Text="{x:Static res:Resources.Word}"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBox Grid.Column="1"
                                                                         Text="{Binding Word}"
                                                                         VerticalAlignment="Center"
                                                                         FontWeight="Bold"/>
                                                            </Grid>
                                                            <Border Grid.Column="1"
                                                                    BorderBrush="#CCC"
                                                                    BorderThickness="1"
                                                                    Padding="6,4"
                                                                    CornerRadius="4">
                                                                <Grid ColumnDefinitions="Auto,160,Auto,160"
                                                                      ColumnSpacing="6"
                                                                      VerticalAlignment="Center">
                                                                    <TextBlock Grid.Column="0"
                                                                               Text="{x:Static res:Resources.WordTiming}"
                                                                               VerticalAlignment="Center"/>
                                                                    <controls:TimeEditorControl Grid.Column="1" TimeValue="{Binding StartTime, Mode=TwoWay}"/>
                                                                    <TextBlock Grid.Column="2"
                                                                               Text="{x:Static res:Resources.RangeSeparator}"
                                                                               VerticalAlignment="Center"/>
                                                                    <controls:TimeEditorControl Grid.Column="3" TimeValue="{Binding EndTime, Mode=TwoWay}"/>
                                                                </Grid>
                                                            </Border>
                                                            <Button Grid.Column="2"
                                                                    Classes="delete-word"
                                                                    Command="{ReflectionBinding DataContext.RemoveLeftWordCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding .}"
                                                                    VerticalAlignment="Center">
                                                                <svg:Svg Path="avares://SpeechMarkupEditor/Assets/trash-can.svg"
                                                                         Width="16"
                                                                         Height="16"/>
                                                            </Button>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,10,0" IsVisible="{Binding !ShowSeries}">
                        <ItemsControl ItemsSource="{Binding LeftSeries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ItemsControl ItemsSource="{Binding Words}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="6,4"
                                                      ColumnDefinitions="*,Auto,Auto"
                                                      ColumnSpacing="12">
                                                    <Grid Grid.Column="0" ColumnDefinitions="Auto,*" ColumnSpacing="6">
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{x:Static res:Resources.Word}"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBox Grid.Column="1"
                                                                 Text="{Binding Word}"
                                                                 VerticalAlignment="Center"
                                                                 FontWeight="Bold"/>
                                                    </Grid>
                                                    <Border Grid.Column="1"
                                                            BorderBrush="#CCC"
                                                            BorderThickness="1"
                                                            Padding="6,4"
                                                            CornerRadius="4">
                                                        <Grid ColumnDefinitions="Auto,160,Auto,160"
                                                              ColumnSpacing="6"
                                                              VerticalAlignment="Center">
                                                            <TextBlock Grid.Column="0"
                                                                       Text="{x:Static res:Resources.WordTiming}"
                                                                       VerticalAlignment="Center"/>
                                                            <controls:TimeEditorControl Grid.Column="1" TimeValue="{Binding StartTime, Mode=TwoWay}"/>
                                                            <TextBlock Grid.Column="2"
                                                                       Text="{x:Static res:Resources.RangeSeparator}"
                                                                       VerticalAlignment="Center"/>
                                                            <controls:TimeEditorControl Grid.Column="3" TimeValue="{Binding EndTime, Mode=TwoWay}"/>
                                                        </Grid>
                                                    </Border>
                                                    <Button Grid.Column="2"
                                                            Classes="delete-word"
                                                            Command="{ReflectionBinding DataContext.RemoveLeftWordCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding .}"
                                                            VerticalAlignment="Center">
                                                        <svg:Svg Path="avares://SpeechMarkupEditor/Assets/trash-can.svg"
                                                                 Width="16"
                                                                 Height="16"/>
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="1"
                    Classes="PanelStyle"
                    BorderBrush="{StaticResource RightLetter}"
                    BorderThickness="1.5"
                    IsVisible="{Binding !IsNonDichoticRecognition}">
                <Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,10,0" IsVisible="{Binding ShowSeries}">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding RightSeries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10" Margin="0,0,0,10" BorderBrush="Gray" BorderThickness="0,0,0,2">
                                            <StackPanel>
                                                <TextBlock Text="{Binding SeriesNumber, StringFormat={x:Static res:Resources.SeriesTitleFormat}}"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource RightLetter}"
                                                           Margin="0,0,0,5"/>
                                                <ItemsControl ItemsSource="{Binding Words}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="6,4"
                                                                  ColumnDefinitions="*,Auto,Auto"
                                                                  ColumnSpacing="12">
                                                                <Grid Grid.Column="0" ColumnDefinitions="Auto,*" ColumnSpacing="6">
                                                                    <TextBlock Grid.Column="0"
                                                                               Text="{x:Static res:Resources.Word}"
                                                                               VerticalAlignment="Center"/>
                                                                    <TextBox Grid.Column="1"
                                                                             Text="{Binding Word}"
                                                                             VerticalAlignment="Center"
                                                                             FontWeight="Bold"/>
                                                                </Grid>
                                                                <Border Grid.Column="1"
                                                                        BorderBrush="#CCC"
                                                                        BorderThickness="1"
                                                                        Padding="6,4"
                                                                        CornerRadius="4">
                                                                    <Grid ColumnDefinitions="Auto,160,Auto,160"
                                                                          ColumnSpacing="6"
                                                                          VerticalAlignment="Center">
                                                                        <TextBlock Grid.Column="0"
                                                                                   Text="{x:Static res:Resources.WordTiming}"
                                                                                   VerticalAlignment="Center"/>
                                                                        <controls:TimeEditorControl Grid.Column="1" TimeValue="{Binding StartTime, Mode=TwoWay}"/>
                                                                        <TextBlock Grid.Column="2"
                                                                                   Text="{x:Static res:Resources.RangeSeparator}"
                                                                                   VerticalAlignment="Center"/>
                                                                        <controls:TimeEditorControl Grid.Column="3" TimeValue="{Binding EndTime, Mode=TwoWay}"/>
                                                                    </Grid>
                                                                </Border>
                                                                <Button Grid.Column="2"
                                                                        Classes="delete-word"
                                                                        Command="{ReflectionBinding DataContext.RemoveRightWordCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding .}"
                                                                        VerticalAlignment="Center">
                                                                    <svg:Svg Path="avares://SpeechMarkupEditor/Assets/trash-can.svg"
                                                                             Width="16"
                                                                             Height="16"/>
                                                                </Button>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,10,0" IsVisible="{Binding !ShowSeries}">
                        <ItemsControl ItemsSource="{Binding RightSeries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ItemsControl ItemsSource="{Binding Words}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="6,4"
                                                      ColumnDefinitions="*,Auto,Auto"
                                                      ColumnSpacing="12">
                                                    <Grid Grid.Column="0" ColumnDefinitions="Auto,*" ColumnSpacing="6">
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{x:Static res:Resources.Word}"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBox Grid.Column="1"
                                                                 Text="{Binding Word}"
                                                                 VerticalAlignment="Center"
                                                                 FontWeight="Bold"/>
                                                    </Grid>
                                                    <Border Grid.Column="1"
                                                            BorderBrush="#CCC"
                                                            BorderThickness="1"
                                                            Padding="6,4"
                                                            CornerRadius="4">
                                                        <Grid ColumnDefinitions="Auto,160,Auto,160"
                                                              ColumnSpacing="6"
                                                              VerticalAlignment="Center">
                                                            <TextBlock Grid.Column="0"
                                                                       Text="{x:Static res:Resources.WordTiming}"
                                                                       VerticalAlignment="Center"/>
                                                            <controls:TimeEditorControl Grid.Column="1" TimeValue="{Binding StartTime, Mode=TwoWay}"/>
                                                            <TextBlock Grid.Column="2"
                                                                       Text="{x:Static res:Resources.RangeSeparator}"
                                                                       VerticalAlignment="Center"/>
                                                            <controls:TimeEditorControl Grid.Column="3" TimeValue="{Binding EndTime, Mode=TwoWay}"/>
                                                        </Grid>
                                                    </Border>
                                                    <Button Grid.Column="2"
                                                            Classes="delete-word"
                                                            Command="{ReflectionBinding DataContext.RemoveRightWordCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding .}"
                                                            VerticalAlignment="Center">
                                                        <svg:Svg Path="avares://SpeechMarkupEditor/Assets/trash-can.svg"
                                                                 Width="16"
                                                                 Height="16"/>
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>

</Window>
