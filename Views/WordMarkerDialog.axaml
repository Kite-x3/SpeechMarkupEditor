<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:SpeechMarkupEditor.ViewModels"
        xmlns:res="clr-namespace:SpeechMarkupEditor.Assets"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="SpeechMarkupEditor.Views.WordMarkerDialog"
        x:DataType="vm:WordMarkerDialogViewModel"
        Width="500" Height="250"
        Title="{x:Static res:Resources.WordMarkerDialogTitle}"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="15, 10" Spacing="5" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Grid RowDefinitions="*, *, *, *, *" ColumnDefinitions="150,220"
              ColumnSpacing="5" RowSpacing="10">
            <TextBlock Grid.Column="0" Grid.Row="0" Text="{x:Static res:Resources.Word}"/>
            <TextBox Grid.Column="1" Grid.Row="0" Text="{Binding Word}"/>

            <TextBlock Grid.Column="0" Grid.Row="1" Text="{x:Static res:Resources.StartTime}"/>
            <Grid Grid.Column="1" Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Text="{Binding StartTimeString, Mode=TwoWay}"
                         Watermark="{x:Static res:Resources.TimeWatermark}"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="+" Width="25" Command="{Binding IncrementStartTimeCommand}"/>
                    <Button Content="-" Width="25" Command="{Binding DecrementStartTimeCommand}"/>
                </StackPanel>
            </Grid>

            <TextBlock Grid.Column="0" Grid.Row="2" Text="{x:Static res:Resources.EndTime}"/>
            <Grid Grid.Column="1" Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Text="{Binding EndTimeString, Mode=TwoWay}"
                         Watermark="{x:Static res:Resources.TimeWatermark}"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="+" Width="25" Command="{Binding IncrementEndTimeCommand}"/>
                    <Button Content="-" Width="25" Command="{Binding DecrementEndTimeCommand}"/>
                </StackPanel>
            </Grid>

            <TextBlock Grid.Column="0" Grid.Row="3" Text="{x:Static res:Resources.EarType}"/>
            <ComboBox Grid.Column="1" Grid.Row="3" ItemsSource="{Binding EarTypes}"
                      SelectedItem="{Binding SelectedEarType}" DisplayMemberBinding="{Binding DisplayName}"/>
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Center">
            <Button Content="Ок" Command="{Binding SubmitCommand}"/>
            <Button Content="{x:Static res:Resources.Cancel}" Command="{Binding CancelCommand}" Margin="5,0,0,0"/>
        </StackPanel>
    </StackPanel>
</Window>