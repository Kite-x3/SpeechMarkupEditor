<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:SpeechMarkupEditor.ViewModels"
        xmlns:rm="using:SpeechMarkupEditor.Models"
        xmlns:res="clr-namespace:SpeechMarkupEditor.Assets"
        mc:Ignorable="d"
        x:Class="SpeechMarkupEditor.Views.ModelSettingsWindow"
        x:DataType="vm:ModelSettingsViewModel"
        Icon="/Assets/SpeechMarkEditor.png"
        Title="{x:Static res:Resources.ModelSettingsTitle}"
        Width="760"
        Height="520"
        WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="Auto,*,Auto" Margin="16" RowSpacing="12">
        <TextBlock Text="{x:Static res:Resources.RecognitionModels}"
                   FontSize="20"
                   FontWeight="SemiBold"/>

        <Grid Grid.Row="1" ColumnDefinitions="*,320" ColumnSpacing="16">
            <Border BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="6" Padding="12">
                <StackPanel Spacing="10">
                    <TextBlock Text="{x:Static res:Resources.AvailableModels}"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Models}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="rm:RecognitionModelDefinition">
                                    <Border Margin="0,0,0,10" Padding="10" BorderBrush="#D8D8D8" BorderThickness="1" CornerRadius="6">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Engine}" Foreground="#666666"/>
                                                <TextBlock Text="{Binding Path}" TextWrapping="Wrap" Foreground="#666666"/>
                                            </StackPanel>
                                            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="8">
                                                <TextBlock Text="{x:Static res:Resources.CurrentModel}" IsVisible="{Binding IsCurrent}" HorizontalAlignment="Right"/>
                                                <Button Content="{x:Static res:Resources.SetCurrentModel}"
                                                        Command="{ReflectionBinding DataContext.SetCurrentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding .}"
                                                        IsVisible="{Binding !IsCurrent}"
                                                        Margin="0 0 0 15"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="6" Padding="12">
                <StackPanel Spacing="12">
                    <TextBlock Text="{x:Static res:Resources.AddModel}"/>
                    <TextBlock Text="{x:Static res:Resources.Type}"/>
                    <TextBox Text="{x:Static res:Resources.VoskEngineName}" Focusable="False" IsReadOnly="True"/>
                    <TextBlock Text="{x:Static res:Resources.Name}"/>
                    <TextBox Text="{Binding NewModelName}"/>
                    <TextBlock Text="{x:Static res:Resources.ModelPath}"/>
                    <TextBox Text="{Binding NewModelPath}"/>
                    <Button Content="{x:Static res:Resources.SelectFolder}"
                            Command="{Binding BrowsePathCommand}"/>
                    <Button Content="{x:Static res:Resources.AddModel}"
                            Command="{Binding AddModelCommand}"/>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{x:Static res:Resources.Close}"
                    Click="CloseButton_OnClick" MinWidth="100"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
