<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SpeechMarkupEditor.App"
             xmlns:local="using:SpeechMarkupEditor"
             RequestedThemeVariant="Light">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <Style Selector="Button">
            <Setter Property="Background" Value="#F2F4F7"/>
            <Setter Property="BorderBrush" Value="#D5DBE3"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#F7F9FC"/>
            <Setter Property="BorderBrush" Value="#C8D0DA"/>
        </Style>
        <Style Selector="DropDownButton">
            <Setter Property="Background" Value="#F2F4F7"/>
            <Setter Property="BorderBrush" Value="#D5DBE3"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="DropDownButton:pointerover">
            <Setter Property="Background" Value="#F7F9FC"/>
            <Setter Property="BorderBrush" Value="#C8D0DA"/>
        </Style>
    </Application.Styles>
</Application>
